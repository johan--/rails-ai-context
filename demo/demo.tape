# VHS demo tape for rails-ai-context install
Output demo.gif

Set Shell zsh
Set FontSize 14
Set Width 950
Set Height 520
Set Padding 12
Set Theme "Catppuccin Mocha"
Set TypingSpeed 35ms

Type "cd ~/my-rails-app"
Enter
Sleep 1s

Type "rails generate rails_ai_context:install"
Sleep 400ms
Enter
Sleep 3s

# Select Claude Code + Cursor
Type "1,2"
Sleep 300ms
Enter
Sleep 2s

# Select MCP mode (yes)
Type "1"
Sleep 300ms
Enter
Sleep 4s

Sleep 2s
